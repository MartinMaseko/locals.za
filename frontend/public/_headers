# CSP is set in netlify.toml — do NOT duplicate it here.
# Two CSP headers are AND'd by browsers (most restrictive wins), causing breakage.

# Service Worker and HTML - always revalidate
/sw.js
  Cache-Control: public, max-age=0, must-revalidate

/index.html
  Cache-Control: public, max-age=0, must-revalidate

/workbox-*.js
  Cache-Control: public, max-age=0, must-revalidate

/manifest.webmanifest
  Cache-Control: public, max-age=0, must-revalidate

# Assets with cache busting (hash in filename) — cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable
